│   └── CONFERENCE_SUBMISSION.md  # Conference submission materials
├── models/                       # Analytical models
│   └── infrastructure/           # Infrastructure inference models
│       ├── capacity_analyzer.py  # Platform capacity analysis
│       └── pattern_capacity_correlator.py # Pattern-capacity correlation
├── standards/                    # Methodological standards
